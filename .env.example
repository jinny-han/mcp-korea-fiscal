# mcp-korea-fiscal — environment variables
#
# Set at least ONE of OPENFISCAL_API_KEY or LOFIN_API_KEY.
# Tools from a subsystem only register if its key is present.

# === 국가재정 (kofin_* tools) ===

# Required for kofin_* tools.
# Get from: https://openfiscaldata.go.kr → 마이페이지 → OpenAPI 신청
OPENFISCAL_API_KEY=

# Optional — supplemental national-fiscal datasets
# DATAGOKR_API_KEY=
# NABOSTATS_API_KEY=

# === 지방재정 (lofin_* tools) ===

# Required for lofin_* tools.
# Get from: https://lofin.mois.go.kr/portal/user/openApi.do
LOFIN_API_KEY=

# === Optional tuning ===
# LOG_LEVEL=info
# CACHE_ENABLED=true
# DEFAULT_PAGE_SIZE=20
# MAX_PAGE_SIZE=100
