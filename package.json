{
  "name": "mcp-korea-fiscal",
  "version": "0.1.0",
  "description": "MCP server for Korean public fiscal data — 국가재정 (열린재정) + 지방재정 (지방재정365)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-korea-fiscal": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    ".env.example"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "node --import tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "fiscal",
    "korea",
    "budget",
    "국가재정",
    "지방재정",
    "openfiscal",
    "lofin365"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "dotenv": "^17.4.2",
    "fast-xml-parser": "^4.5.0",
    "opossum": "^9.0.0",
    "p-limit": "^7.3.0",
    "p-retry": "^8.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/opossum": "^8.1.9",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  }
}
